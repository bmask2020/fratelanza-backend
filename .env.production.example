NODE_ENV=production
PORT=3000
DATABASE_URL="postgresql://username:password@db-host:5432/fratelanza"
CORS_ORIGINS="https://fratelanza.com,https://admin.fratelanza.com"
ENABLE_SWAGGER="false"
JWT_ACCESS_SECRET="replace-with-production-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-production-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
ADMIN_EMAIL="admin@fratelanza.com"
ADMIN_PASSWORD_HASH="replace-with-production-bcrypt-hash"
STORAGE_DRIVER="local"
UPLOAD_DESTINATION="/var/www/fratelanza/uploads"
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME_TYPES="application/pdf,image/jpeg,image/png,image/webp"
ALLOWED_UPLOAD_EXTENSIONS=".pdf,.jpg,.jpeg,.png,.webp"
UPLOAD_SCAN_MODE="basic"
MONITORING_ENABLED="true"
MONITORING_PROVIDER="log"
MONITORING_DSN="replace-when-using-external-monitoring"